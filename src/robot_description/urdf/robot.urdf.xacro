<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="robot">

  <!-- Include inertial macros (opsional, karena sudah inline di robot_core_highres) -->
  <xacro:include filename="inertial_macros.xacro"/>

  <!-- Core robot definition dengan visual, collision, inertial -->
  <xacro:include filename="robot_core_highres.xacro"/>

</robot>